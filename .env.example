# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Application name displayed in logs, API health check, and service identifiers
# Default: Allo-Scrapper
APP_NAME=Allo-Scrapper

# Application name for React frontend (browser title, header, footer)
# 
# IMPORTANT: This variable behaves differently in development vs production:
# 
# LOCAL DEVELOPMENT (npm run dev):
#   - Vite reads this from .env file at runtime
#   - Used by import.meta.env.VITE_APP_NAME in React components
# 
# PRODUCTION DOCKER BUILD:
#   - The app name is set via Docker build ARG in Dockerfile (default: Allo-Scrapper)
#   - GitHub Actions passes this as a build argument
#   - Vite substitutes %VITE_APP_NAME% in index.html at build time
#   - To customize: modify the build-args in docker-compose.yml or GitHub Actions
# 
# Default: Allo-Scrapper
VITE_APP_NAME=Allo-Scrapper

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# PostgreSQL connection settings
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ics
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password

# Alternative: Full database URL (if provided, overrides individual settings above)
# DATABASE_URL=postgresql://postgres:password@localhost:5432/ics

# ============================================================================
# DATABASE MIGRATION CONFIGURATION
# ============================================================================

# Automatically apply pending database migrations at server startup
# When true (default): Runs migrations automatically before server starts
# When false: Migrations must be applied manually via SQL files
# 
# Recommended: true for production, false only for debugging migration issues
# 
# Fresh installs: Migrations create all tables and seed default admin user
# Upgrades: Only new migrations are applied automatically
# 
AUTO_MIGRATE=true

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================

# Node environment (development | production | test)
NODE_ENV=development

# Port for Express server
PORT=3000

# JSON parse cache size for database query optimization
# Controls the maximum number of cached JSON.parse results for repeated
# database fields (genres, actors, experiences).
# Higher values = better hit rate but more memory usage.
# Lower values = less memory but more cache misses.
# Default: 10000 entries (~1-2 MB memory depending on data)
# Recommended: Keep default unless you have specific memory constraints
# Set to 0 to disable caching (not recommended - significant performance impact)
JSON_PARSE_CACHE_SIZE=10000

# CORS allowed origins (comma-separated)
# Must include every origin the browser uses to reach the app.
#
# When running via Docker (docker compose up), the frontend is served by the same
# Express server on port 3000 — include that origin here.
# When running in dev mode (Vite), also include http://localhost:5173.
#
# IMPORTANT for LAN/production installs: if you access the app from another
# machine (e.g. http://192.168.1.100:3000), you MUST add that origin too.
# Example: ALLOWED_ORIGINS=http://localhost:3000,http://192.168.1.100:3000
#
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Timezone for cron jobs (IANA timezone format)
TZ=Europe/Paris

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================

# JWT secret for signing authentication tokens
# 
# ⚠️ CRITICAL SECURITY REQUIREMENT:
# - This MUST be set in production (no default fallback for security)
# - Generate a strong random secret: openssl rand -base64 32
# - Minimum length: 32 characters (256 bits recommended)
# - Never commit this secret to version control
# - Use different secrets for dev/staging/production
# - Rotating this secret will invalidate all existing user sessions
#
# Example generation commands:
#   openssl rand -base64 32
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#
# For development ONLY (DO NOT use in production):
JWT_SECRET=dev-secret-key-change-in-prod

# PRODUCTION - generate and use a secure secret:
# JWT_SECRET=<paste-your-generated-secret-here>

# ============================================================================
# RATE LIMITING CONFIGURATION
# ============================================================================

# Rate limit window in milliseconds (default: 900000 = 15 minutes)
# All counters reset after this time window
RATE_LIMIT_WINDOW_MS=900000

# General API rate limit (applies to all /api/* routes)
# Default: 100 requests per window
# Example: With default 15min window, allows ~6.6 requests/minute
RATE_LIMIT_GENERAL_MAX=100

# Authentication rate limit (applies to /api/auth/login)
# ⚠️ SECURITY: Counts only FAILED login attempts (successful logins are skipped)
# Default: 5 failed attempts per window
# Helps prevent brute-force password attacks
RATE_LIMIT_AUTH_MAX=5

# Registration rate limit (applies to /api/auth/register)
# Default: 3 registrations per hour
# Prevents spam account creation
RATE_LIMIT_REGISTER_MAX=3
RATE_LIMIT_REGISTER_WINDOW_MS=3600000

# Protected endpoints rate limit (applies to /api/reports/*)
# Default: 60 requests per window
# Authenticated users can make more requests than public endpoints
RATE_LIMIT_PROTECTED_MAX=60

# Scraper trigger rate limit (applies to /api/scraper/trigger)
# Default: 10 requests per window
# Prevents triggering too many concurrent scrapes
RATE_LIMIT_SCRAPER_MAX=10

# Public endpoints rate limit (applies to /api/films/*, /api/cinemas/*)
# Default: 100 requests per window
# Same as general limit, but can be configured separately for public API
RATE_LIMIT_PUBLIC_MAX=100

# ============================================================================
# DOCKER CONFIGURATION
# ============================================================================

# Docker image tag for ics-web service (when using pre-built images)
# Default: latest
# Examples: latest, v1.0.0, main, develop
IMAGE_TAG=latest

# ============================================================================
# SCRAPER CONFIGURATION
# ============================================================================

# Cron schedule for automatic scraping (cron format: minute hour dayOfMonth month dayOfWeek)
# Default: Every Wednesday at 8:00 AM
SCRAPE_CRON_SCHEDULE=0 8 * * 3

# Delay in milliseconds between each CINEMA scrape to avoid rate limiting
# This delay is applied after scraping all dates for one cinema before moving to the next.
# Recommended: 3000ms (3 seconds) to avoid 429 Too Many Requests errors
# Lower values = faster scraping but higher risk of being rate-limited
# Higher values = slower but safer (use 5000+ for strict rate limits)
SCRAPE_THEATER_DELAY_MS=3000

# Delay in milliseconds between MOVIE detail page fetches
# This delay is applied when fetching film metadata (duration, director, synopsis, etc.)
# Recommended: 500ms (0.5 seconds)
# Film details are fetched less frequently than showtimes, so lower delay is acceptable
SCRAPE_MOVIE_DELAY_MS=500

# Number of days to scrape starting from start date
# Default: 7 (full week)
# Min: 1, Max: 14
SCRAPE_DAYS=7

# Scrape mode: 
# - 'weekly': Start from current/previous Wednesday (7 days by default)
# - 'from_today': Start from current date
# - 'from_today_limited': Start from today until Tuesday (max 7 days)
# Default: weekly
# Note: Automatic cron jobs always use 'weekly' mode with 7 days
SCRAPE_MODE=weekly

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================

# Redis connection URL (used by backend and scraper microservice)
REDIS_URL=redis://localhost:6379

# ============================================================================
# SCRAPER MICROSERVICE CONFIGURATION
# ============================================================================

# Feature flag: set to "true" to use the Redis-based scraper microservice
# When false (default), the legacy in-process scraper is used
USE_REDIS_SCRAPER=false

# Scraper container run mode:
# - "consumer"  : Long-running process polling Redis queue (for ics-scraper)
# - "cron"      : Scheduled scraping on CRON_SCHEDULE (for ics-scraper-cron)
# - "oneshot"   : Pop one job and exit
# - "direct"    : Run once immediately and exit
RUN_MODE=consumer

# ============================================================================
# LOGGING & OBSERVABILITY
# ============================================================================

# Log level for Winston (error | warn | info | debug)
# Default: info
LOG_LEVEL=info

# OpenTelemetry – distributed tracing (Tempo)
# Set OTEL_ENABLED=true when running the monitoring profile
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://ics-tempo:4317

# ============================================================================
# CLIENT CONFIGURATION (for React frontend)
# ============================================================================

# API base URL for the React app during LOCAL DEVELOPMENT ONLY
# This is used by Vite dev server (npm run dev) to configure API request proxying.
# 
# PRODUCTION DOCKER BUILDS: This variable is NOT needed and is ignored.
# The production frontend uses relative URLs (/api) which automatically work
# with any hostname (localhost, LAN IP, domain name).
#
# Only set this when running the React app in development mode via Vite.
# Default: http://localhost:3000/api
VITE_API_BASE_URL=http://localhost:3000/api
