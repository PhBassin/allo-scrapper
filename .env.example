# ============================================================================
# Allo-Scrapper — environment configuration
# Copy to .env and fill in the required values
# ============================================================================

# Application
APP_NAME=Allo-Scrapper
VITE_APP_NAME=Allo-Scrapper

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ics
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-password-here
# DATABASE_URL=postgresql://postgres:password@localhost:5432/ics

# Auto-apply migrations at startup (default: true)
AUTO_MIGRATE=true

# Server
NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
TZ=Europe/Paris

# Authentication (REQUIRED)
# Generate: openssl rand -base64 64
JWT_SECRET=
# JWT_PREVIOUS_SECRETS=oldsecret1,oldsecret2
JWT_EXPIRES_IN=1h
COOKIE_SECURE=true
REFRESH_TOKEN_EXPIRY=7d

# Docker
IMAGE_TAG=latest
DOCKER_UID=1000
DOCKER_GID=1000

# Redis
REDIS_URL=redis://localhost:6379

# Scraper
SCRAPE_MODE=weekly
SCRAPE_DAYS=7
SCRAPE_CRON_SCHEDULE=0 8 * * 3
SCRAPE_THEATER_DELAY_MS=3000
SCRAPE_MOVIE_DELAY_MS=500
SCRAPER_CONCURRENCY=2
RUN_MODE=consumer

# Logging
LOG_LEVEL=info
