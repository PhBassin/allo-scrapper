# ============================================================================
# Allo-Scrapper — environment configuration
# Copy to .env and fill in required values
# ============================================================================

# ── Required ──────────────────────────────────────────────────────────────────

# PostgreSQL
POSTGRES_PASSWORD=your-secure-password-here

# Authentication (generate with: openssl rand -base64 64)
JWT_SECRET=

# ── Deployment ────────────────────────────────────────────────────────────────

IMAGE_TAG=stable                          # Docker image tag (stable, latest, v4.2.0)
ALLOWED_ORIGINS=http://localhost:3000      # CORS origins (comma-separated)
PORT=3000                                  # (docker-compose.yaml hardcodes 3000)

# ── Optional (defaults shown) ─────────────────────────────────────────────────

TZ=Europe/Paris
LOG_LEVEL=info
JWT_EXPIRES_IN=1h
AUTO_MIGRATE=true

# ── Database override ─────────────────────────────────────────────────────────
# Used by docker-compose.build.yml and docker-compose.dev.yml.
# docker-compose.yaml hardcodes these; DATABASE_URL overrides all.

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ics
POSTGRES_USER=postgres
# DATABASE_URL=postgresql://postgres:password@localhost:5432/ics

# ── Scraper (hardcoded in docker-compose.yaml, override for dev) ──────────────

SCRAPE_CRON_SCHEDULE=0 8 * * 3            # cron expression
SCRAPE_MODE=weekly                         # weekly | from_today | from_today_limited
SCRAPE_DAYS=7                              # 1–14
SCRAPE_THEATER_DELAY_MS=3000               # ms between theaters
SCRAPE_MOVIE_DELAY_MS=500                  # ms between movie detail pages
SCRAPER_CONCURRENCY=2                      # parallel theater scrapes

# ── Dev only ──────────────────────────────────────────────────────────────────

SERVER_PORT=3000                           # docker-compose.dev.yml
CLIENT_PORT=5173                           # docker-compose.dev.yml
NODE_ENV=development                       # set to production in docker-compose.yaml

# ── Advanced ──────────────────────────────────────────────────────────────────

# JWT_PREVIOUS_SECRETS=oldsecret1,oldsecret2   # smooth secret rotation
# COOKIE_SECURE=true                            # HTST Secure cookie flag
# REFRESH_TOKEN_EXPIRY=7d                       # refresh token lifetime
# REDIS_URL=redis://localhost:6379              # (docker-compose.yaml hardcodes this)
# APP_NAME=Allo-Scrapper                        # app name in logs
