# Copy to .env, fill in required values, ready to deploy.
# docker-compose.yaml reads these 5 variables — everything else is hardcoded.

# Docker image tag (stable, latest, or specific version like v4.2.0)
IMAGE_TAG=stable

# PostgreSQL password for the database container
POSTGRES_PASSWORD=your-secure-password-here

# CORS allowed origins (your Coolify domain, comma-separated)
# Example: https://my-app.xyz,https://www.my-app.xyz
ALLOWED_ORIGINS=http://localhost:3000

# Cron schedule for automatic scraping (minute hour dayOfMonth month dayOfWeek)
# Default: every Wednesday at 08:00 AM
SCRAPE_CRON_SCHEDULE=0 8 * * 3

# REQUIRED — JWT signing key for authentication tokens
# Minimum 32 characters. Generate with: openssl rand -base64 64
# WARNING: the server refuses to start without this
JWT_SECRET=
