{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["opencode-plugin-mempalace"],
  "tools": {
    "skill": true
  },
  "permission": {
    "skill": {
      "*": "allow"
    }
  },
  "mcp": {
