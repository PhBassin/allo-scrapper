# docker-compose.dev.yml / docker-compose.build.yml
# Append to .env for local development:  cat .env.example .env.dev.example > .env

# ── PostgreSQL (overrides for local/dev) ──────────────────────────────────────

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ics
POSTGRES_USER=postgres

# ── Dev server ────────────────────────────────────────────────────────────────

SERVER_PORT=3000
CLIENT_PORT=5173
NODE_ENV=development

# ── App defaults ──────────────────────────────────────────────────────────────

TZ=Europe/Paris
LOG_LEVEL=info
JWT_EXPIRES_IN=24h
PORT=3000

# ── Scraper ───────────────────────────────────────────────────────────────────

SCRAPE_MODE=weekly
SCRAPE_DAYS=7
SCRAPE_THEATER_DELAY_MS=3000
SCRAPE_MOVIE_DELAY_MS=500
SCRAPER_CONCURRENCY=2
SCRAPE_DELAY_MS=1000

# ── Advanced (optional, uncomment to override) ────────────────────────────────

# AUTO_MIGRATE=true
# COOKIE_SECURE=true
# REFRESH_TOKEN_EXPIRY=7d
# REDIS_URL=redis://localhost:6379
# APP_NAME=Allo-Scrapper
